# ==================================================
# APPLICATION ENVIRONMENT
# ==================================================
# Set to 'development' for local dev (uses original CSS/JS files)
# Set to 'production' for live server (uses minified, hashed assets)
APP_ENV=development

CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

LEMONSQUEEZY_TEST_API_KEY=
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=

# ==================================================
# POLAR.SH CONFIGURATION
# ==================================================

# Test Mode: Set to 'true' to use sandbox, 'false' for production
POLAR_TEST_MODE=false

POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_ACCESS_TOKEN_SANDBOX=
POLAR_WEBHOOK_SECRET_SANDBOX=
POLAR_CHECKOUT_ANNUAL=
POLAR_CHECKOUT_LIFETIME=
POLAR_CHECKOUT_ANNUAL_SANDBOX=
POLAR_CHECKOUT_LIFETIME_SANDBOX=


OPENAI_API_KEY=

UNSPLASH_API_ACCESS_KEY=
UNSPLASH_API_SECRET_KEY=
UNSPLASH_APPLICATION_ID=
# GitHub OAuth Configuration (for GitHub export feature)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/github-oauth.php

# ===================================
# DATABASE CONFIGURATION
# ===================================
# Database Environment: 'local', 'remote', or 'production'
DB_ENV=local

# ===================================
# LOCAL DATABASE CONFIGURATION
# ===================================
DB_LOCAL_HOST=127.0.0.1
DB_LOCAL_NAME=fpstudio
DB_LOCAL_USER=root
DB_LOCAL_PASS=
DB_LOCAL_PORT=3306

# ===================================
# REMOTE DATABASE CONFIGURATION (via SSH Tunnel)
# ===================================
# Use this for remote testing via SSH tunnel (like TablePlus)
# The SSH tunnel should be set up separately (e.g., via TablePlus or SSH command)
# Then connect to 127.0.0.1 on the tunnel port
DB_REMOTE_HOST=127.0.0.1
DB_REMOTE_NAME=fpstudio
DB_REMOTE_USER=fpstudio
DB_REMOTE_PASS=
DB_REMOTE_PORT=3306

# SSH Tunnel Configuration (for reference - tunnel must be set up separately)
# SSH Server: 95.216.154.45
# SSH Port: 522
# SSH User: dbssh
# Remote MySQL Host: 127.0.0.1 (on remote server)
# Remote MySQL Port: 3306
# 
# To set up SSH tunnel manually:
# ssh -L 3306:127.0.0.1:3306 -p 522 dbssh@95.216.154.45

# ===================================
# PRODUCTION DATABASE CONFIGURATION
# ===================================
DB_PROD_HOST=127.0.0.1
DB_PROD_NAME=fpstudio
DB_PROD_USER=fpstudio
DB_PROD_PASS=
DB_PROD_PORT=3306

# ===================================
# LEGACY PURCHASES DATABASE CONFIGURATION
# ===================================
# External database connection for the purchases table
# (separate from the main fpstudio database)
PURCHASES_DB_HOST=nocn.noc-n.com
PURCHASES_DB_NAME=alvarotrigo_alvarotrigo
PURCHASES_DB_USER=alvarotrigo_alvarotrigo
PURCHASES_DB_PASS=


# ==================================================
# OPENSRS DOMAIN REGISTRATION
# ==================================================
# Test Mode: Set to 'true' to use Horizon sandbox, 'false' for production
OPENSRS_TEST_MODE=true

OPENSRS_USERNAME=
OPENSRS_API_KEY_TEST=
OPENSRS_API_KEY=


# ===================================
# ADMIN PANEL CONFIGURATION
# ===================================
# Email address of the admin user who can access /admin
# This should be the email you use to log in with Clerk
# IMPORTANT: Only this email will have access to the admin panel
ADMIN_EMAIL=your@email.com
