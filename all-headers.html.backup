<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Navigation Bar Collection</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="dist/css/sections.css">
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <style>
    :root {
      --primary-bg: #ffffff;
      --secondary-bg: #f4f4f7;
      --accent-bg: #fafafa;
      --primary-text: #222222;
      --secondary-text: #777777;
      --accent-text: #111111;
      --primary-accent: #5046e6;
      --primary-accent-soft: rgba(80, 70, 230, 0.1);
      --secondary-accent: #3d31d9;
      --border-color: transparent;
      --shadow-color: rgba(0, 0, 0, 0.05);
      --shadow-sm: none;
      --shadow-md: none;
      --shadow-lg: none;
      --card-shadow: none;
      --card-shadow-hover: none;
      --section-shadow: none;
      --gradient-1: linear-gradient(135deg, #f4f4f7 0%, #fafafa 100%);
      --gradient-2: linear-gradient(135deg, var(--primary-accent) 0%, var(--secondary-accent) 100%);
      --features2-bg: linear-gradient(135deg, var(--primary-accent) 0%, var(--secondary-accent) 100%);
      --button-on-gradient: #ffffff;
      --button-on-gradient-border: rgba(255, 255, 255, 0.8);
      --font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      --heading-font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      --border-radius: 16px;
      --button-radius: 50px;
      --card-radius: 20px;
      --spacing-unit: 1.4rem;
      --header-max-width: 100%;
      --nav-element-max-width: none;
      --nav-border-color: rgba(0, 0, 0, 0.08);
    }

    body {
      font-family: var(--font-family);
      background-color: var(--primary-bg);
    }

    .nav-container {
      margin-bottom: 3rem;
    }

    /* Apply max-width to nav element itself */
    nav {
      max-width: var(--nav-element-max-width);
      margin-left: auto;
      margin-right: auto;
    }

    /* Navigation link styles - prevent text wrapping */
    nav a, nav span, nav button {
      white-space: nowrap;
    }

    .mobile-menu {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease-out;
    }
    .mobile-menu.open {
      max-height: 500px;
    }

    /* Light mode class */
    .nav-light {
      --primary-bg: #ffffff;
      --secondary-bg: #f4f4f7;
      --accent-bg: #fafafa;
      --primary-text: #222222;
      --secondary-text: #777777;
      --accent-text: #111111;
      --primary-accent: #5046e6;
      --primary-accent-soft: rgba(80, 70, 230, 0.1);
      --secondary-accent: #3d31d9;
      --nav-border-color: rgba(0, 0, 0, 0.08);
      --gradient-1: linear-gradient(135deg, #f4f4f7 0%, #fafafa 100%);
      --gradient-2: linear-gradient(135deg, var(--primary-accent) 0%, var(--secondary-accent) 100%);
      --button-on-gradient: #ffffff;
      --button-on-gradient-border: rgba(255, 255, 255, 0.8);
    }

    /* Dark mode class */
    .nav-dark {
      --primary-bg: #000000;
      --secondary-bg: #222222;
      --accent-bg: #1a1a1a;
      --primary-text: #ffffff;
      --secondary-text: #aaaaaa;
      --accent-text: #ffffff;
      --primary-accent: #8b5cf6;
      --primary-accent-soft: rgba(139, 92, 246, 0.1);
      --secondary-accent: #7c3aed;
      --nav-border-color: rgba(255, 255, 255, 0.1);
      --gradient-1: linear-gradient(135deg, #1a1a1a 0%, #222222 100%);
      --gradient-2: linear-gradient(135deg, var(--primary-accent) 0%, var(--secondary-accent) 100%);
      --button-on-gradient: #ffffff;
      --button-on-gradient-border: rgba(255, 255, 255, 0.8);
    }

    /* Theme classes - Renamed for consistency */
    .nav-theme-light {
      --primary-bg: #ffffff;
      --primary-accent: #ffffff;
      --secondary-bg: #f4f4f7;
      --accent-bg: #fafafa;
      --primary-text: #222222;
      --secondary-text: #777777;
      --accent-text: #111111;
      --primary-accent-soft: rgba(80, 70, 230, 0.1);
      --nav-border-color: rgba(0, 0, 0, 0.08);
      --button-on-gradient-border: rgba(255, 255, 255, 0.8);
    }

    .nav-theme-dark {
      --primary-bg: #000000;
      --primary-accent: #000000;
      --secondary-bg: #222222;
      --accent-bg: #1a1a1a;
      --primary-text: #ffffff;
      --secondary-text: #aaaaaa;
      --accent-text: #ffffff;
      --primary-accent-soft: rgba(139, 92, 246, 0.1);
      --nav-border-color: rgba(255, 255, 255, 0.1);
      --button-on-gradient: #ffffff;
      --button-on-gradient-border: rgba(255, 255, 255, 0.8);
    }

    /* Accent theme - uses primary accent as background */
    .nav-theme-accent {
      --secondary-bg: var(--secondary-accent);
      --primary-text: #ffffff;
      --secondary-text: rgba(255, 255, 255, 0.8);
      --accent-text: #ffffff;
      --nav-border-color: rgba(255, 255, 255, 0.2);
    }

    /* Background Classes */
    /* Solid background - opaque, uses theme colors */
    .nav-bg-solid {
      background-color: var(--primary-accent);
    }

    /* Transparent background - no background */
    .nav-bg-transparent {
      background-color: transparent;
    }

    /* Glass background - semi-transparent with blur */
    .nav-bg-glass {
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px); /* Safari support */
    }

    /* Glass background colors based on theme */
    .nav-theme-light.nav-bg-glass {
      background-color: rgba(255, 255, 255, 0.7);
    }

    .nav-theme-dark.nav-bg-glass {
      background-color: rgba(0, 0, 0, 0.7);
    }

    /* Accent theme glass - will be set via JavaScript */
    .nav-theme-accent.nav-bg-glass {
      /* Set dynamically based on accent color */
    }

    /* Corner Classes */
    /* Sharp corners - no radius, full width */
    .nav-corners-sharp {
      border-radius: 0 !important;
    }

    /* Rounded corners - uses card radius, full width */
    .nav-corners-rounded {
      border-radius: var(--card-radius) !important;
    }

    /* Pill corners - high radius, constrained width */
    .nav-corners-pill {
      border-radius: 50px !important;
      max-width: 1200px !important;
      margin-left: auto !important;
      margin-right: auto !important;
    }

    /* Responsive pill style */
    @media (max-width: 768px) {
      .nav-corners-pill {
        max-width: calc(100% - 2rem) !important;
        margin-left: 1rem !important;
        margin-right: 1rem !important;
      }
    }

    /* Shadow styles */
    .nav-shadow-none {
      box-shadow: none !important;
    }

    .nav-shadow-subtle {
      box-shadow: 0 4px 6px -1px var(--shadow-color),
                  0 2px 4px -2px var(--shadow-color) !important;
    }

    /* Content wrapper - always enforce max-width */
    .nav-content-wrapper {
      max-width: 1200px;
      margin: 0 auto;
    }

    /* Max width container helper - keep for backwards compatibility */
    .nav-max-width-container {
      max-width: var(--header-max-width);
      margin: 0 auto;
    }

    /* Control panel styles */
    .control-panel {
      position: fixed;
      top: 20px;
      right: 20px;
      z-index: 1000;
      background: white;
      border: 2px solid #e5e7eb;
      border-radius: 12px;
      padding: 1.25rem;
      box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
      max-width: 320px;
      max-height: 90vh;
      overflow: hidden;
      transition: max-height 0.3s ease, padding 0.3s ease;
    }

    .control-panel.collapsed {
      max-height: 60px;
      padding: 12px;
    }

    .control-panel-toggle {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0;
      margin: 0 0 12px 0;
    }

    .control-panel.collapsed .control-panel-toggle {
      margin-bottom: 0;
    }

    .control-panel-toggle h2 {
      margin: 0;
      font-size: 1.125rem;
      font-weight: 700;
      color: var(--primary-text);
    }

    .control-panel-chevron {
      transition: transform 0.3s ease;
      color: var(--primary-text);
    }

    .control-panel.collapsed .control-panel-chevron {
      transform: rotate(-90deg);
    }

    .control-panel-content {
      max-height: calc(90vh - 60px);
      overflow-y: auto;
      transition: opacity 0.3s ease, max-height 0.3s ease;
    }

    .control-panel.collapsed .control-panel-content {
      max-height: 0;
      opacity: 0;
      overflow: hidden;
    }

    .control-panel-content::-webkit-scrollbar {
      width: 6px;
    }

    .control-panel-content::-webkit-scrollbar-track {
      background: #f1f1f1;
      border-radius: 10px;
    }

    .control-panel-content::-webkit-scrollbar-thumb {
      background: #888;
      border-radius: 10px;
    }

    .control-panel-content::-webkit-scrollbar-thumb:hover {
      background: #555;
    }

    .control-group {
      margin-bottom: 0;
      padding-bottom: 1rem;
      border-bottom: 1px solid #f3f4f6;
    }

    .control-group:last-child {
      margin-bottom: 0;
      padding-bottom: 0;
      border-bottom: none;
    }

    .control-label {
      font-weight: 600;
      font-size: 0.8125rem;
      color: #374151;
      margin-bottom: 0.625rem;
      display: block;
    }

    .radio-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .radio-option {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      cursor: pointer;
    }

    .radio-option input[type="radio"] {
      cursor: pointer;
      width: 1rem;
      height: 1rem;
    }

    .radio-option label {
      cursor: pointer;
      font-size: 0.875rem;
      color: #4b5563;
    }

    .theme-dropdown {
      display: none;
      margin-top: 0.75rem;
      padding: 0.75rem;
      background: #f9fafb;
      border-radius: 0.5rem;
      border: 1px solid #e5e7eb;
    }

    .theme-dropdown.active {
      display: block;
    }

    .theme-dropdown select {
      width: 100%;
      padding: 0.5rem;
      border: 1px solid #d1d5db;
      border-radius: 0.375rem;
      font-size: 0.875rem;
      background: white;
      cursor: pointer;
    }

    .theme-dropdown select:focus {
      outline: none;
      border-color: #5046e6;
      box-shadow: 0 0 0 3px rgba(80, 70, 230, 0.1);
    }

    /* Responsive adjustments for mobile */
    @media (max-width: 768px) {
      .control-panel {
        top: 10px;
        right: 10px;
        left: 10px;
        max-width: none;
        padding: 1rem;
      }
    }

    /* CTA Style Classes */
    /* Text link style: no background, no border, accent color */
    .nav-cta-text {
      background: transparent !important;
      border: none !important;
    }

    /* Outline style: transparent background, accent border */
    .nav-cta-outline {
      background: transparent !important;
      border: 1px solid var(--accent-text) !important;
      color: var(--primary-text) !important;
    }

    /* Solid style: accent background, white text */
    .nav-cta-solid {
      background: var(--secondary-accent) !important;
      border: 1px solid transparent !important;
      color: #fff !important;
    }
  </style>
</head>
<body class="p-0">
  <!-- Control Panel -->
  <div class="control-panel" id="control-panel">
    <button class="control-panel-toggle" id="control-panel-toggle">
      <h2>Navigation Controls</h2>
      <i data-lucide="chevron-down" class="control-panel-chevron" style="width: 20px; height: 20px;"></i>
    </button>

    <div class="control-panel-content" id="control-panel-content">
      <div class="space-y-4">
      <!-- Background Option -->
      <div class="control-group">
        <span class="control-label">Background</span>
        <div class="radio-group">
          <div class="radio-option">
            <input type="radio" id="bg-solid" name="background" value="solid" checked>
            <label for="bg-solid">Solid</label>
          </div>
          <div class="radio-option">
            <input type="radio" id="bg-transparent" name="background" value="transparent">
            <label for="bg-transparent">Transparent</label>
          </div>
          <div class="radio-option">
            <input type="radio" id="bg-glass" name="background" value="glass">
            <label for="bg-glass">Glass</label>
          </div>
        </div>
      </div>

      <!-- Corners Option -->
      <div class="control-group">
        <span class="control-label">Corners</span>
        <div class="radio-group">
          <div class="radio-option">
            <input type="radio" id="corners-sharp" name="corners" value="sharp">
            <label for="corners-sharp">Sharp</label>
          </div>
          <div class="radio-option">
            <input type="radio" id="corners-rounded" name="corners" value="rounded" checked>
            <label for="corners-rounded">Rounded</label>
          </div>
          <div class="radio-option">
            <input type="radio" id="corners-pill" name="corners" value="pill">
            <label for="corners-pill">Pill</label>
          </div>
        </div>
      </div>

      <!-- Theme Option -->
      <div class="control-group">
        <span class="control-label">Theme</span>
        <div class="radio-group">
          <div class="radio-option">
            <input type="radio" id="theme-dark" name="theme" value="dark">
            <label for="theme-dark">Dark</label>
          </div>
          <div class="radio-option">
            <input type="radio" id="theme-light" name="theme" value="light" checked>
            <label for="theme-light">Light</label>
          </div>
          <div class="radio-option">
            <input type="radio" id="theme-accent" name="theme" value="accent">
            <label for="theme-accent">Accent</label>
          </div>
        </div>

        <!-- Theme Color Selector Dropdown (always visible) -->
        <div id="theme-dropdown" class="theme-dropdown active">
          <label for="theme-select" class="control-label">Theme Colors</label>
          <select id="theme-select">
            <option value="theme-light-grey-minimal" selected>Light Grey Minimal (Default)</option>
            <option value="theme-light-minimal">Light Minimal</option>
            <option value="theme-dark-modern">Dark Modern</option>
            <option value="theme-corporate-clean">Corporate Clean</option>
            <option value="theme-playful-colorful">Playful Colorful</option>
            <option value="theme-elegant-serif">Elegant Serif</option>
            <option value="theme-wellness-calm">Wellness Calm</option>
            <option value="theme-professional-navy">Professional Navy</option>
            <option value="theme-sunset-warm">Sunset Warm</option>
            <option value="theme-ocean-breeze">Ocean Breeze</option>
            <option value="theme-forest-natural">Forest Natural</option>
            <option value="theme-luxury-gold">Luxury Gold</option>
          </select>
        </div>
      </div>

      <!-- Shadow Option -->
      <div class="control-group">
        <span class="control-label">Shadow</span>
        <div class="radio-group">
          <div class="radio-option">
            <input type="radio" id="shadow-none" name="shadow" value="none" checked>
            <label for="shadow-none">None</label>
          </div>
          <div class="radio-option">
            <input type="radio" id="shadow-subtle" name="shadow" value="subtle">
            <label for="shadow-subtle">Subtle</label>
          </div>
        </div>
      </div>

      <!-- CTA Style Option -->
      <div class="control-group">
        <span class="control-label">CTA Style</span>
        <div class="radio-group">
          <div class="radio-option">
            <input type="radio" id="cta-auto" name="cta-style" value="auto" checked>
            <label for="cta-auto">Auto (Recommended)</label>
          </div>
          <div class="radio-option">
            <input type="radio" id="cta-text" name="cta-style" value="text">
            <label for="cta-text">Text Link</label>
          </div>
          <div class="radio-option">
            <input type="radio" id="cta-outline" name="cta-style" value="outline">
            <label for="cta-outline">Outline</label>
          </div>
          <div class="radio-option">
            <input type="radio" id="cta-solid" name="cta-style" value="solid">
            <label for="cta-solid">Solid</label>
          </div>
        </div>
      </div>

      <!-- Background Image Control -->
      <div class="control-group">
        <span class="control-label">Background Type</span>
        <div class="radio-option">
          <input type="checkbox" id="use-background-image" name="use-background-image">
          <label for="use-background-image">Use Background Image</label>
        </div>
        <div id="background-image-input" style="margin-top: 0.75rem; display: none;">
          <input
            type="text"
            id="background-image-url"
            placeholder="Enter image URL"
            value="https://images.unsplash.com/photo-1512598483799-b7f979b5f2b3?q=80&w=3442&auto=format&fit=crop"
            style="width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; font-size: 0.875rem;"
          />
        </div>
      </div>
      </div>
    </div>
  </div>

  <div class="p-8">
    <h1 class="text-3xl font-bold mb-8 text-center" style="color: var(--primary-text);">Navigation Bar Collection</h1>

  <!-- Nav 1: Classic with pill CTA -->
  <div class="nav-container">
    <p class="text-sm mb-2 font-medium" style="color: var(--primary-text);">1. Classic with Pill CTA</p>
    <nav class="nav-bg-solid nav-corners-rounded nav-theme-light px-6 py-4">
      <div class="nav-content-wrapper">

        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40" class="w-10 h-10">
              <rect width="40" height="40" rx="8" fill="var(--secondary-accent)"/>
              <text x="50%" y="50%" dominant-baseline="central" text-anchor="middle" fill="var(--primary-bg)" font-family="system-ui, -apple-system, sans-serif" font-size="20" font-weight="600">B</text>
            </svg>
            <span class="font-bold text-xl" style="color: var(--accent-text);">BrandName</span>
          </div>
          <div class="hidden md:flex items-center gap-8">
            <a href="#" class="font-medium hover:opacity-70 transition-opacity" style="color: var(--primary-text);">How it works</a>
            <a href="#" class="font-medium hover:opacity-70 transition-opacity" style="color: var(--primary-text);">Examples</a>
            <a href="#" class="font-medium hover:opacity-70 transition-opacity" style="color: var(--primary-text);">Pricing</a>
            <a href="#" class="font-medium hover:opacity-70 transition-opacity" style="color: var(--primary-text);">Blog</a>
          </div>
          <div class="hidden md:flex items-center gap-3">
            <a href="#" class="px-4 py-2 font-medium rounded-full border transition-all hover:opacity-80" style="color: var(--primary-text); border-color: var(--secondary-text);">
              Sign in
            </a>
            <a href="#" class="px-5 py-2 font-medium rounded-full transition-all hover:opacity-90" style="background: var(--secondary-accent); border-radius: var(--button-radius);color: var(--primary-text);">
              Start for Free →
            </a>
          </div>
          <button class="md:hidden p-2" onclick="toggleMenu('menu1')" style="color: var(--primary-text);">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
        </div>
        <div id="menu1" class="mobile-menu md:hidden">
          <div class="pt-4 pb-2 flex flex-col gap-3">
            <a href="#" class="py-2 font-medium" style="color: var(--primary-text);">How it works</a>
            <a href="#" class="py-2 font-medium" style="color: var(--primary-text);">Examples</a>
            <a href="#" class="py-2 font-medium" style="color: var(--primary-text);">Pricing</a>
            <a href="#" class="py-2 font-medium" style="color: var(--primary-text);">Blog</a>
            <a href="#" class="mt-2 px-5 py-2 font-medium rounded-full" style="background: var(--secondary-accent);color: var(--primary-text);">Start for Free</a>
          </div>
        </div>
    
      </div>
    </nav>
  </div>

  <!-- Nav 3: With badge/counter -->
  <div class="nav-container">
    <p class="text-sm mb-2 font-medium" style="color: var(--primary-text);">3. With Badge Counter</p>
    <nav class="nav-bg-solid nav-corners-rounded nav-theme-light px-6 py-4">
      <div class="nav-content-wrapper">

        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40" class="w-10 h-10">
                <rect width="40" height="40" rx="8" fill="var(--secondary-accent)"/>
                <text x="50%" y="50%" dominant-baseline="central" text-anchor="middle" fill="var(--primary-bg)" font-family="system-ui, -apple-system, sans-serif" font-size="20" font-weight="600">F</text>
              </svg>

              <span class="font-bold text-xl" style="color: var(--accent-text);">fullPage.js</span>
            </div>
          </div>
          <div class="hidden lg:flex items-center gap-6">
            <a href="#" class="font-medium hover:opacity-70" style="color: var(--primary-text);">WordPress</a>
            <a href="#" class="font-medium hover:opacity-70" style="color: var(--primary-text);">Docs</a>
            <a href="#" class="font-medium hover:opacity-70" style="color: var(--primary-text);">Resources</a>
            <a href="#" class="font-medium hover:opacity-70" style="color: var(--primary-text);">Extensions</a>
            <a href="#" class="px-5 py-2 font-medium rounded-lg" style="background-color: var(--primary-accent);">
              Purchase
            </a>
          </div>
          <button class="lg:hidden p-2" onclick="toggleMenu('menu3')" style="color: var(--primary-text);">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
        </div>
        <div id="menu3" class="mobile-menu lg:hidden">
          <div class="pt-4 pb-2 flex flex-col gap-3">
            <a href="#" class="py-2 font-medium" style="color: var(--primary-text);">WordPress</a>
            <a href="#" class="py-2 font-medium" style="color: var(--primary-text);">Docs</a>
            <a href="#" class="py-2 font-medium" style="color: var(--primary-text);">Resources</a>
            <a href="#" class="py-2 font-medium" style="color: var(--primary-text);">Extensions</a>
