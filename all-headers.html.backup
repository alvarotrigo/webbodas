            <a href="#" class="py-2 font-medium" style="color: var(--primary-text);">Solutions</a>
            <a href="#" class="py-2 font-medium" style="color: var(--primary-text);">Developers</a>
            <a href="#" class="py-2 font-medium" style="color: var(--primary-text);">Partners</a>
            <a href="#" class="py-2 font-medium" style="color: var(--primary-text);">Pricing</a>
            <a href="#" class="mt-2 px-5 py-2 font-medium" style="background-color: var(--primary-accent); border-radius: var(--button-radius);">Sign up</a>
          </div>
        </div>
    
      </div>
    </nav>
  </div>

  <!-- Nav 30: Minimal Adidas Style - Clean, No BG, Simple Links -->
  <div class="nav-container">
    <p class="text-sm mb-2 font-medium" style="color: var(--primary-text);">30. Minimal Adidas Style - Clean, No BG, Simple Links</p>
    <nav class="nav-bg-transparent nav-corners-rounded nav-theme-light px-6 py-5">
      <div class="nav-content-wrapper">

        <div class="flex items-center justify-between">
          <svg xmlns="http://www.w3.org/2000/svg" width="50" height="30" viewBox="0 0 50 30" class="h-8">
            <rect width="50" height="30" fill="var(--secondary-accent)"/>
            <text x="50%" y="50%" dominant-baseline="central" text-anchor="middle" fill="var(--primary-bg)" font-family="system-ui, -apple-system, sans-serif" font-size="18" font-weight="700">T</text>
          </svg>
          <div class="hidden md:flex items-center gap-10">
            <a href="#" class="font-bold uppercase text-sm tracking-wide hover:opacity-70 transition-opacity" style="color: var(--primary-text);">Heren</a>
            <a href="#" class="font-bold uppercase text-sm tracking-wide hover:opacity-70 transition-opacity" style="color: var(--primary-text);">Dames</a>
            <a href="#" class="font-bold uppercase text-sm tracking-wide hover:opacity-70 transition-opacity" style="color: var(--primary-text);">Kinderen</a>
            <a href="#" class="font-bold uppercase text-sm tracking-wide hover:opacity-70 transition-opacity" style="color: var(--primary-text);">Schoenen</a>
            <a href="#" class="font-bold uppercase text-sm tracking-wide hover:opacity-70 transition-opacity" style="color: var(--primary-text);">Sporten</a>
            <a href="#" class="font-bold uppercase text-sm tracking-wide hover:opacity-70 transition-opacity" style="color: var(--primary-text);">Outlet</a>
          </div>
          <div class="flex items-center gap-4">
            <svg class="w-6 h-6 cursor-pointer hover:opacity-70" style="color: var(--primary-text);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <svg class="hidden sm:block w-6 h-6 cursor-pointer hover:opacity-70" style="color: var(--primary-text);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            <svg class="hidden sm:block w-6 h-6 cursor-pointer hover:opacity-70" style="color: var(--primary-text);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
            <svg class="w-6 h-6 cursor-pointer hover:opacity-70" style="color: var(--primary-text);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
            <button class="md:hidden p-2" onclick="toggleMenu('menu30')" style="color: var(--primary-text);">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
            </button>
          </div>
        </div>
        <div id="menu30" class="mobile-menu md:hidden">
          <div class="pt-4 pb-2 flex flex-col gap-3">
            <a href="#" class="py-2 font-bold uppercase text-sm tracking-wide" style="color: var(--primary-text);">Heren</a>
            <a href="#" class="py-2 font-bold uppercase text-sm tracking-wide" style="color: var(--primary-text);">Dames</a>
            <a href="#" class="py-2 font-bold uppercase text-sm tracking-wide" style="color: var(--primary-text);">Kinderen</a>
            <a href="#" class="py-2 font-medium uppercase text-sm tracking-wide" style="color: var(--secondary-text);">Schoenen</a>
            <a href="#" class="py-2 font-medium uppercase text-sm tracking-wide" style="color: var(--secondary-text);">Sporten</a>
            <a href="#" class="py-2 font-bold uppercase text-sm tracking-wide" style="color: var(--primary-text);">Outlet</a>
          </div>
        </div>
    
      </div>
    </nav>
  </div>

  </div> <!-- Close p-8 div -->

  <script>
    // Keep existing toggleMenu function for mobile menus
    function toggleMenu(menuId) {
      const menu = document.getElementById(menuId);
      menu.classList.toggle('open');
    }

    // Configuration
    const CLASS_PREFIXES = {
      background: 'nav-bg-',
      corners: 'nav-corners-',
      theme: 'nav-theme-',
      shadow: 'nav-shadow-',
      ctaStyle: 'nav-cta-'
    };

    let currentConfig = {
      background: 'solid',
      corners: 'rounded',
      theme: 'light',
      shadow: 'none',
      ctaStyle: 'auto',
      selectedTheme: 'theme-light-grey-minimal',
      useBackgroundImage: false,
      backgroundImageUrl: 'https://images.unsplash.com/photo-1512598483799-b7f979b5f2b3?q=80&w=3442&auto=format&fit=crop'
    };

    // DOM references
    const backgroundRadios = document.querySelectorAll('input[name="background"]');
    const cornersRadios = document.querySelectorAll('input[name="corners"]');
    const themeRadios = document.querySelectorAll('input[name="theme"]');
    const shadowRadios = document.querySelectorAll('input[name="shadow"]');
    const ctaStyleRadios = document.querySelectorAll('input[name="cta-style"]');
    const themeDropdown = document.getElementById('theme-dropdown');
    const themeSelect = document.getElementById('theme-select');
    const useBackgroundImageCheckbox = document.getElementById('use-background-image');
    const backgroundImageInput = document.getElementById('background-image-input');
    const backgroundImageUrl = document.getElementById('background-image-url');
    const allNavs = document.querySelectorAll('nav');
    const body = document.body;

    // Remove all classes with a specific prefix
    function removeClassesWithPrefix(element, prefix) {
      const classesToRemove = Array.from(element.classList)
        .filter(cls => cls.startsWith(prefix));
      classesToRemove.forEach(cls => element.classList.remove(cls));
    }

    /**
     * Convert any color format to rgba with specified opacity
     */
    function colorToRgba(color, opacity) {
      // Create a temporary element to parse the color
      const temp = document.createElement('div');
      temp.style.color = color;
      document.body.appendChild(temp);

      // Get computed color (always returns rgb/rgba format)
      const computedColor = window.getComputedStyle(temp).color;
      document.body.removeChild(temp);

      // Parse rgb/rgba values
      const rgbMatch = computedColor.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)(?:,\s*[\d.]+)?\)/);

      if (rgbMatch) {
        const r = rgbMatch[1];
        const g = rgbMatch[2];
        const b = rgbMatch[3];
        return `rgba(${r}, ${g}, ${b}, ${opacity})`;
      }

      return color; // Fallback to original color if parsing fails
    }

    /**
     * Apply body background color or image based on theme and settings
     */
    function applyBodyBackground() {
      const theme = currentConfig.theme;

      // Check if background image should be used
      if (currentConfig.useBackgroundImage) {
        const imageUrl = currentConfig.backgroundImageUrl.trim();
        if (imageUrl) {
          body.style.backgroundImage = `url('${imageUrl}')`;
          body.style.backgroundSize = 'cover';
          body.style.backgroundPosition = 'center';
          body.style.backgroundRepeat = 'no-repeat';
          body.style.backgroundAttachment = 'fixed';
          // Remove background color to let image show
          body.style.backgroundColor = '';
          return;
        }
      }

      // Remove background image styles if not using image
      body.style.backgroundImage = '';
      body.style.backgroundSize = '';
      body.style.backgroundPosition = '';
      body.style.backgroundRepeat = '';
      body.style.backgroundAttachment = '';

      // Apply background color based on theme
      if (theme === 'light') {
        body.style.backgroundColor = '#e5e5e5';
      } else if (theme === 'dark') {
        body.style.backgroundColor = '#160f33';
      } else if (theme === 'accent') {
        // Use --primary-bg which is set to var(--primary-accent) in nav-theme-accent
        body.style.backgroundColor = 'var(--primary-bg)';
      }
    }

    /**
     * Apply glass effect for accent theme
     */
    function applyAccentGlass() {
      if (currentConfig.theme === 'accent' && currentConfig.background === 'glass') {
        // Get the primary-bg color (which is set to accent color in nav-theme-accent)
        const accentGlassNavs = document.querySelectorAll('.nav-theme-accent.nav-bg-glass');

        accentGlassNavs.forEach(nav => {
          const computedBg = window.getComputedStyle(nav).getPropertyValue('--primary-bg').trim();
          // If it's a CSS variable reference, get the computed value
          const accentColor = computedBg.startsWith('var(')
            ? getComputedStyle(document.documentElement).getPropertyValue('--primary-accent').trim()
            : computedBg;

          // Convert to rgba with 0.7 opacity
          const glassColor = colorToRgba(accentColor, 0.7);
          nav.style.backgroundColor = glassColor;
        });
      }
    }

    /**
     * Apply body theme class
     */
    function applyBodyTheme() {
      // Remove all theme classes from body
      body.className = body.className.replace(/theme-[\w-]+/g, '').trim();

      // Always add selected theme class (for all themes, not just accent)
      // This ensures --primary-accent and other theme colors are available for buttons, logos, etc.
      body.classList.add(currentConfig.selectedTheme);

      // Ensure p-0 class remains
      if (!body.classList.contains('p-0')) {
        body.classList.add('p-0');
      }
    }

    /**
     * Apply CTA styles based on the selected mode
     */
    function applyCtaStyles() {
      const ctaStyle = currentConfig.ctaStyle;

      allNavs.forEach(nav => {
        // Find all CTA buttons in the desktop nav (not in mobile menu)
        // CTA buttons are typically <a> or <button> elements with classes like:
        // - "px-" (padding) and either background or border styling
        // - Located in the rightmost section of the nav
        const ctaContainers = nav.querySelectorAll('.hidden.md\\:flex, .hidden.lg\\:flex');

        ctaContainers.forEach(container => {
          // Find potential CTA elements (a or button tags with specific styling patterns)
          const potentialCtas = Array.from(container.querySelectorAll('a, button'))
            .filter(el => {
              // Exclude hamburger menu buttons
              if (el.querySelector('svg path[d*="M4 6h16"]')) return false;

              // Include elements with padding that look like buttons
              const classList = el.className;
              return classList.includes('px-') &&
                     (classList.includes('py-') || classList.includes('p-'));
            });

          // Identify actual CTAs (usually the rightmost buttons in the container)
          const ctas = potentialCtas.slice(-3); // Take up to last 3 as potential CTAs
          const ctaCount = ctas.length;

          // Remove any existing CTA style classes
          ctas.forEach(cta => {
            cta.classList.remove('nav-cta-text', 'nav-cta-outline', 'nav-cta-solid');
          });

          // Apply styles based on mode
          if (ctaStyle === 'text') {
            // All CTAs become text links
            ctas.forEach(cta => cta.classList.add('nav-cta-text'));
          } else if (ctaStyle === 'outline') {
            // All CTAs become outline buttons
            ctas.forEach(cta => cta.classList.add('nav-cta-outline'));
          } else if (ctaStyle === 'solid') {
            // All CTAs become solid buttons
            ctas.forEach(cta => cta.classList.add('nav-cta-solid'));
          } else if (ctaStyle === 'auto') {
            // Auto mode: apply progressive emphasis
            if (ctaCount === 1) {
              // 1 CTA: Solid
              ctas[0].classList.add('nav-cta-solid');
            } else if (ctaCount === 2) {
              // 2 CTAs: Outline + Solid
              ctas[0].classList.add('nav-cta-outline');
              ctas[1].classList.add('nav-cta-solid');
            } else if (ctaCount >= 3) {
              // 3+ CTAs: Text + Outline + Solid
              ctas[0].classList.add('nav-cta-text');
              ctas[1].classList.add('nav-cta-outline');
              ctas[2].classList.add('nav-cta-solid');
            }
          }
        });
      });
    }

    // Apply a specific option to all navs
    function applyOption(optionType, value) {
      // CTA style is handled differently - it applies to individual buttons, not the nav element
      if (optionType === 'ctaStyle') {
        currentConfig[optionType] = value;
        applyCtaStyles();
        saveConfigToStorage();
        return;
      }

      const prefix = CLASS_PREFIXES[optionType];
      const className = prefix + value;

      allNavs.forEach(nav => {
        removeClassesWithPrefix(nav, prefix);
        nav.classList.add(className);
      });

      currentConfig[optionType] = value;

      // Handle theme-specific updates
      if (optionType === 'theme') {
        applyBodyTheme();
        applyBodyBackground();

        // Wait for styles to be applied, then apply accent glass if needed
        setTimeout(() => {
          applyAccentGlass();
        }, 10);
      }

      // Handle background changes with accent theme
      if (optionType === 'background' && currentConfig.theme === 'accent') {
        setTimeout(() => {
          applyAccentGlass();
        }, 10);
      }

      saveConfigToStorage();
    }

    // Apply all configurations
    function applyAllConfigurations() {
      allNavs.forEach(nav => {
        Object.values(CLASS_PREFIXES).forEach(prefix => {
          // Don't remove CTA style classes from nav - they're applied to individual buttons
          if (prefix === CLASS_PREFIXES.ctaStyle) return;
          removeClassesWithPrefix(nav, prefix);
        });

        nav.classList.add(CLASS_PREFIXES.background + currentConfig.background);
        nav.classList.add(CLASS_PREFIXES.corners + currentConfig.corners);
        nav.classList.add(CLASS_PREFIXES.theme + currentConfig.theme);
        nav.classList.add(CLASS_PREFIXES.shadow + currentConfig.shadow);
        // Don't add ctaStyle class to nav - it's applied to individual buttons
      });

      applyBodyTheme();
      applyBodyBackground();
      applyCtaStyles();

      // Wait for styles to be applied, then apply accent glass if needed
      setTimeout(() => {
        applyAccentGlass();
      }, 10);
    }

    // localStorage persistence
    function saveConfigToStorage() {
      localStorage.setItem('navConfig', JSON.stringify(currentConfig));
    }

    function loadConfigFromStorage() {
      const saved = localStorage.getItem('navConfig');
      if (saved) {
        try {
          const parsed = JSON.parse(saved);
          currentConfig = { ...currentConfig, ...parsed };

          // Sync theme selector if we have a saved theme
          if (currentConfig.selectedTheme && themeSelect) {
            themeSelect.value = currentConfig.selectedTheme;
          }

          return true;
        } catch (e) {
          console.error('Failed to parse saved config:', e);
        }
      }
      return false;
    }

    function syncRadiosToConfig() {
      const bgRadio = document.getElementById(`bg-${currentConfig.background}`);
      const cornersRadio = document.getElementById(`corners-${currentConfig.corners}`);
      const themeRadio = document.getElementById(`theme-${currentConfig.theme}`);
      const shadowRadio = document.getElementById(`shadow-${currentConfig.shadow}`);
      const ctaRadio = document.getElementById(`cta-${currentConfig.ctaStyle}`);

      if (bgRadio) bgRadio.checked = true;
      if (cornersRadio) cornersRadio.checked = true;
      if (themeRadio) themeRadio.checked = true;
      if (shadowRadio) shadowRadio.checked = true;
      if (ctaRadio) ctaRadio.checked = true;
    }

    // Event listeners
    backgroundRadios.forEach(radio => {
      radio.addEventListener('change', () => {
        if (radio.checked) applyOption('background', radio.value);
      });
    });

    cornersRadios.forEach(radio => {
      radio.addEventListener('change', () => {
        if (radio.checked) applyOption('corners', radio.value);
      });
    });

    themeRadios.forEach(radio => {
      radio.addEventListener('change', () => {
        if (radio.checked) applyOption('theme', radio.value);
      });
    });

    shadowRadios.forEach(radio => {
      radio.addEventListener('change', () => {
        if (radio.checked) applyOption('shadow', radio.value);
      });
    });

    ctaStyleRadios.forEach(radio => {
      radio.addEventListener('change', () => {
        if (radio.checked) applyOption('ctaStyle', radio.value);
      });
    });

    // Theme selector dropdown
    themeSelect.addEventListener('change', () => {
      currentConfig.selectedTheme = themeSelect.value;
      applyBodyTheme();

      // Reapply configurations to pick up new theme colors
      setTimeout(() => {
        applyAccentGlass();
        applyBodyBackground();
      }, 10);

      saveConfigToStorage();
    });

    // Background image checkbox
    useBackgroundImageCheckbox.addEventListener('change', () => {
      currentConfig.useBackgroundImage = useBackgroundImageCheckbox.checked;

      if (useBackgroundImageCheckbox.checked) {
        backgroundImageInput.style.display = 'block';
      } else {
        backgroundImageInput.style.display = 'none';
      }

      applyBodyBackground();
      saveConfigToStorage();
    });

    // Background image URL input
    backgroundImageUrl.addEventListener('input', () => {
      currentConfig.backgroundImageUrl = backgroundImageUrl.value;

      if (currentConfig.useBackgroundImage) {
        applyBodyBackground();
        saveConfigToStorage();
      }
    });

    // Initialization
    window.addEventListener('DOMContentLoaded', () => {
      loadConfigFromStorage();
      syncRadiosToConfig();

      // Sync background image controls
      if (currentConfig.useBackgroundImage) {
        useBackgroundImageCheckbox.checked = true;
        backgroundImageInput.style.display = 'block';
      }
      if (currentConfig.backgroundImageUrl) {
        backgroundImageUrl.value = currentConfig.backgroundImageUrl;
      }

      applyAllConfigurations();

      // Initialize lucide icons
      if (typeof lucide !== 'undefined') {
        lucide.createIcons();
      }

      // Control panel toggle functionality
      const controlPanelToggle = document.getElementById('control-panel-toggle');
      const controlPanel = document.getElementById('control-panel');

      if (controlPanelToggle && controlPanel) {
        controlPanelToggle.addEventListener('click', () => {
          controlPanel.classList.toggle('collapsed');
          // Reinitialize icons after toggle
          setTimeout(() => {
            if (typeof lucide !== 'undefined') {
              lucide.createIcons();
            }
          }, 100);
        });
      }
    });
  </script>
</body>
</html>